# API 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型配置（留空使用默认值）
MODEL_GM=gpt-4o
MODEL_ACTOR=gpt-4o
MODEL_SCRIBE=gpt-4o
MODEL_ARCHIVIST=gpt-4o-mini

# 项目路径配置（默认: .novel）
PROJECT_DIR=.novel

# 数据存储目录（默认: ./.data_store）
DATA_STORE_DIR=./.data_store

# 启用 Agent 系统提示词日志（设置为 1 启用，日志写入 .novel/.working/agent-logs.jsonl）
DEBUG_PROMPTS=
